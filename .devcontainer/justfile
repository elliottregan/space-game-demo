# Start the container
up:
    docker compose up -d

# Stop the container
down:
    docker compose down

# SSH into the container (with agent forwarding for git)
ssh:
    ssh -A -p 2222 dev@localhost

# Run claude with skip permissions
claude:
    docker exec -it -u dev -w /workspace space-game-devcontainer claude --dangerously-skip-permissions

# Run claude with debug logging
claude-debug:
    docker exec -it -u dev -w /workspace space-game-devcontainer claude --debug

# Rebuild the container
rebuild:
    docker compose down
    docker compose build --no-cache
    docker compose up -d

# Extract Claude OAuth credentials from macOS Keychain to ~/.claude
extract-credentials:
    security find-generic-password -s "Claude Code-credentials" -a "$(whoami)" -w > ~/.claude/.credentials.json
    @echo "Credentials extracted to ~/.claude/.credentials.json"

# Refresh credentials (container picks up changes via bind mount)
refresh-auth:
    just extract-credentials
    @echo "Auth refreshed"
