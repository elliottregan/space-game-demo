# Start the container
up:
    docker compose up -d

# Stop the container
down:
    docker compose down

# SSH into the container
ssh:
    ssh -p 2222 node@localhost

# Run claude with skip permissions
claude:
    docker exec -it -u node -w /workspace space-game-devcontainer claude --dangerously-skip-permissions

# Rebuild the container
rebuild:
    docker compose down
    docker compose build --no-cache
    docker compose up -d
