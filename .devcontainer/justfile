# Start the container
up:
    docker compose up -d

# Stop the container
down:
    docker compose down

# SSH into the container
ssh:
    ssh -p 2222 dev@localhost

# Run claude with skip permissions
claude:
    docker exec -it -u dev -w /workspace space-game-devcontainer claude --dangerously-skip-permissions

# Rebuild the container
rebuild:
    docker compose down
    docker compose build --no-cache
    docker compose up -d

# Extract Claude OAuth credentials from macOS Keychain
extract-credentials:
    security find-generic-password -s "Claude Code-credentials" -a "$(whoami)" -w > .credentials.json
    @echo "Credentials extracted to .credentials.json"

# Refresh credentials and restart container
refresh-auth:
    just extract-credentials
    docker compose down
    docker compose up -d
    @echo "Auth refreshed and container restarted"
