{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Default IDE config - includes everything for editor support
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "types": ["bun", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "index.ts",
    "vite.config.ts",
    "vite.visualizer.config.ts"
  ],
  "exclude": ["node_modules"]
}
