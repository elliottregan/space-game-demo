{
  "name": "space-game-demo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint ./src",
    "lint:fix": "oxlint --fix ./src",
    "format": "oxfmt ./src ./scripts",
    "format:check": "oxfmt --check ./src ./scripts",
    "typecheck": "tsc -p tsconfig.core.json --noEmit && tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.scripts.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "typecheck:core": "tsc -p tsconfig.core.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "test": "bun test",
    "simulate": "bun run scripts/simulate.ts",
    "visualize": "bun run scripts/visualize.ts",
    "build:visualizer": "vite build --config vite.visualizer.config.ts",
    "preview:visualizer": "vite preview --config vite.visualizer.config.ts",
    "dev:visualizer": "vite dev --config vite.visualizer.config.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-force": "^3.0.10",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^25.2.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "lefthook": "^2.0.16",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.1.1",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@vue-flow/core": "^1.48.2",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "lucide-vue-next": "^0.563.0",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  }
}
